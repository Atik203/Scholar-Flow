# Local development env
NODE_ENV=development
PORT=5000
# Required by prisma client
USE_PGVECTOR=true
DATABASE_URL=
DIRECT_DATABASE_URL=
OPTIMIZE_API_KEY=""
# Used by auth middleware/routes
NEXTAUTH_SECRET="your-64-char-hex-secret-here"
FRONTEND_URL="http://localhost:3000"
WS_URL="http://localhost:5001"

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=


# JWT Configuration
JWT_SECRET="your-jwt-secret-here"
EXPIRES_IN="3d"
REFRESH_TOKEN_SECRET="your-refresh-secret-here"
REFRESH_TOKEN_EXPIRES_IN="15d"
RESET_PASS_TOKEN="your-reset-secret-here"
RESET_PASS_TOKEN_EXPIRES_IN="10m"

# Email Configuration
EMAIL=
APP_PASS=
RESET_PASS_LINK="http://localhost:3000/reset-password"
VERIFY_EMAIL_LINK="http://localhost:3000/verify-email"

# Resend API key (transactional emails) — optional, falls back to SMTP/Gmail
RESEND_API_KEY="re_xxxx"

# AI Provider Configuration
# Add keys for the providers you want to enable. Providers with empty keys are auto-disabled.
OPENAI_API_KEY="sk----J8-HA--"
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""       # Claude (anthropic.com) — leave empty to disable
DEEPSEEK_API_KEY=""         # DeepSeek (deepseek.com) — leave empty to disable
AI_PROVIDER_FALLBACK_ORDER="openai,gemini,claude,deepseek"
AI_FEATURES_ENABLED=true
AI_REQUEST_TIMEOUT_MS=15000

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY="/r+pII"
AWS_BUCKET_NAME="--"
AWS_REGION="-"


# Stripe Configuration
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret_here"
STRIPE_PRICE_PRO_MONTHLY="price_pro_monthly_id"
STRIPE_PRICE_PRO_ANNUAL="price_pro_annual_id"
STRIPE_PRICE_TEAM_MONTHLY="price_team_monthly_id"
STRIPE_PRICE_TEAM_ANNUAL="price_team_annual_id"
STRIPE_PRICE_ENTERPRISE_MONTHLY="price_enterprise_monthly_id"
STRIPE_PRICE_ENTERPRISE_ANNUAL="price_enterprise_annual_id"
STRIPE_BILLING_PORTAL_RETURN_URL="http://localhost:3000/dashboard/billing"

# SSLCommerz Configuration (for Bangladesh)
STORE_ID=""
STORE_PASS="@ssl"
SUCCESS_URL="http://localhost:3000/payment/success"
CANCEL_URL="http://localhost:3000/payment/cancel"
FAIL_URL="http://localhost:3000/payment/fail"
SSL_PAYMENT_API="https://sandbox.sslcommerz.com/gwprocess/v4/api.php"
SSL_VALIDATIOIN_API="https://sandbox.sslcommerz.com/validator/api/validationserverAPI.php"

# Redis (for background jobs) - Redis Cloud
REDIS_URL=""
REDIS_HOST=""
REDIS_PORT=""
REDIS_DB="0"
REDIS_PASSWORD=""
REDIS_USERNAME="default"


FEATURE_UPLOADS=true
MAX_UPLOAD_MB=25
ALLOWED_UPLOAD_MIME=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document
TEXT_EXTRACTION_TIMEOUT_MS=20000
CHUNK_MAX_TOKENS=800
VIRUS_SCAN_ENABLED=false

# Document Preview (DOCX→PDF conversion)
# Engine: soffice (LibreOffice) is free, zero-infra, and recommended for most deployments.
# Gotenberg is optional for higher-volume production — run as Docker sidecar on same VPS.
DOCX_TO_PDF_ENGINE=soffice
# Gotenberg service URL (only needed when DOCX_TO_PDF_ENGINE=gotenberg)
GOTENBERG_URL=
# Optional timeout (ms) for health checks/requests to Gotenberg (default 10000)
GOTENBERG_TIMEOUT_MS=10000
# Conversion quality: draft | screen | print | prepress (default: print)
DOCX_TO_PDF_QUALITY=print
