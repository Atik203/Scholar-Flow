# Socket Server Configuration
# Copy this to .env and fill in your values

PORT=5001

# Must match the NEXTAUTH_SECRET (or BETTER_AUTH_SECRET) used by frontend
# better-auth signs JWTs with this secret; socket server verifies them
NEXTAUTH_SECRET="your-secret-here"

# Frontend URL for CORS (comma-separated if multiple origins)
FRONTEND_URL="http://localhost:3000"
