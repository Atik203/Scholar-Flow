{
  "name": "scholar-flow",
  "version": "1.3.0-rc1",
  "description": "AI-Powered Research Paper Collaboration Hub",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend",
    "apps/socket-server"
  ],
  "scripts": {
    "dev": "yarn workspace @scholar-flow/backend dev & yarn workspace @scholar-flow/frontend dev & yarn workspace @scholar-flow/socket-server dev",
    "dev:all": "yarn dev",
    "dev:turbo": "turbo run dev",
    "dev:backend": "yarn workspace @scholar-flow/backend dev",
    "dev:frontend": "yarn workspace @scholar-flow/frontend dev",
    "build": "corepack enable 2>/dev/null; turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{js,ts,tsx,md,json}\"",
    "setup": "yarn install --immutable && yarn workspace @scholar-flow/backend prisma generate --sql",
    "setup:clean": "yarn clean && yarn install && yarn workspace @scholar-flow/backend prisma generate --sql",
    "db:migrate": "yarn workspace @scholar-flow/backend prisma migrate dev",
    "db:generate": "yarn workspace @scholar-flow/backend prisma generate --sql",
    "db:studio": "yarn workspace @scholar-flow/backend prisma studio",
    "db:seed": "yarn workspace @scholar-flow/backend ts-node prisma/seed.js",
    "db:reset": "yarn workspace @scholar-flow/backend prisma migrate reset --force",
    "repomix": "npx repomix"
  },
  "devDependencies": {
    "@turbo/gen": "^2.5.5",
    "@types/add": "^2",
    "@types/node": "^20",
    "@types/react-window": "^1",
    "@types/sanitize-html": "^2.16.0",
    "prettier": "^3.0.3",
    "prisma": "^7.8.0",
    "repomix": "^1.14.1",
    "rimraf": "^5.0.5",
    "turbo": "^2.9.16",
    "typescript": "^5.2.2"
  },
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0",
    "yarn": ">=4.9.2"
  },
  "packageManager": "yarn@4.9.2",
  "resolutions": {
    "prosemirror-model": "^1.25.0",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.38.0"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "add": "^2.0.6",
    "beasties": "^0.3.5",
    "critters": "^0.0.25",
    "lucide-react": "^0.542.0",
    "motion": "^12.40.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-window": "^1.8.11",
    "sanitize-html": "^2.17.0"
  }
}
